# ── Groww Trade API ────────────────────────────────────────────────────────────
# Get these from https://groww.in/trade-api/api-keys
GROWW_API_KEY=your_api_key_here
GROWW_API_SECRET=your_api_secret_here

# Set to true to use the growwapi Python SDK instead of raw REST calls
GROWW_USE_SDK=false

# ── Telegram alerts ────────────────────────────────────────────────────────────
# Create a bot via @BotFather, get chat ID via @userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Ollama / LLM (news sentiment) ──────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma3

# ── Database ───────────────────────────────────────────────────────────────────
# Leave blank to use default: data_store/nse_agent.db
DB_URL=

# ── Logging ────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── Paper trading ──────────────────────────────────────────────────────────────
PAPER_TRADING_CAPITAL=100000
LIVE_TRADING_ENABLED=false
